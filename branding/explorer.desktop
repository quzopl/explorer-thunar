[Desktop Entry]
Type=Application
Version=1.0
Name=Explorer
Comment=Windows-style file manager built on the Thunar engine
Exec=explorer %F
Icon=system-file-manager
Terminal=false
Categories=System;Utility;Core;GTK;FileManager;
StartupNotify=true
StartupWMClass=explorer
MimeType=inode/directory;application/x-gnome-saved-search;
