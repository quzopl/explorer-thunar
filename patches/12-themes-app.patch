+/* Explorer: dostawca CSS aktywnego motywu (żywa zmiana w trakcie działania) */
+static GtkCssProvider *explorer_theme_provider = NULL;
+
+void
+thunar_application_apply_theme (const gchar *slug)
+{
+  GtkSettings *settings;
+  gchar       *file;
+  gchar       *full;
+  gboolean     dark;
+
+  if (slug == NULL || *slug == '\0')
+    slug = "fluent-dark";
+
+  /* slug kończący się na "-light" => motyw jasny */
+  dark = (g_str_has_suffix (slug, "-light") == FALSE);
+
+  settings = gtk_settings_get_default ();
+  if (settings != NULL)
+    g_object_set (settings,
+                  "gtk-application-prefer-dark-theme", dark,
+                  "gtk-icon-theme-name", dark ? "Win11-dark" : "Win11",
+                  NULL);
+
+  if (explorer_theme_provider == NULL)
+    {
+      explorer_theme_provider = gtk_css_provider_new ();
+      gtk_style_context_add_provider_for_screen (gdk_screen_get_default (),
+                                                 GTK_STYLE_PROVIDER (explorer_theme_provider),
+                                                 GTK_STYLE_PROVIDER_PRIORITY_APPLICATION + 1);
+    }
+
+  file = g_strconcat (slug, ".css", NULL);
+  full = g_build_filename (DATADIR, "explorer", "themes", file, NULL);
+  gtk_css_provider_load_from_path (explorer_theme_provider, full, NULL);
+  g_free (full);
+  g_free (file);
+}
+
+void
+thunar_application_set_theme (const gchar *slug)
+{
+  if (slug == NULL || *slug == '\0')
+    return;
+  xfconf_channel_set_string (xfconf_channel_get ("explorer"), "/explorer-theme", slug);
+  thunar_application_apply_theme (slug);
+}
