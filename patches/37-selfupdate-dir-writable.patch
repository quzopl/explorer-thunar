+/* czy AppImage da sie podmienic: rename wymaga prawa zapisu w katalogu */
+static gboolean
+thunar_explorer_appimage_replaceable (const gchar *appimage)
+{
+  gchar   *dir = g_path_get_dirname (appimage);
+  gboolean ok = access (dir, W_OK) == 0;
+
+  g_free (dir);
+  return ok;
+}
