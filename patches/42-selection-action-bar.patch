  * update the image previews.
  **/
 static void
+thunar_window_explorer_selbar_update (ThunarWindow *window)
+{
+  GList *files = NULL;
+  guint  n;
+
+  if (window->explorer_selbar == NULL)
+    return;
+
+  if (window->view != NULL)
+    g_object_get (G_OBJECT (window->view), "selected-files", &files, NULL);
+  n = g_list_length (files);
+  thunar_g_list_free_full (files);
+
+  if (n > 0)
+    {
+      gchar *text = g_strdup_printf (_("Selected: %u"), n);
+      gtk_label_set_text (GTK_LABEL (window->explorer_selbar_label), text);
+      g_free (text);
+    }
+  gtk_revealer_set_reveal_child (GTK_REVEALER (window->explorer_selbar), n > 0);
+}
