+/* Explorer: sprawdzanie aktualizacji (GitHub Releases API przez curl).
+ * EXPLORER_VERSION wstrzykuje build (scripts/build*.sh) z tagu gita. */
+#ifndef EXPLORER_VERSION
+#define EXPLORER_VERSION "dev"
+#endif
+#define EXPLORER_RELEASES_URL "https://github.com/quzopl/explorer-thunar/releases/latest"
+#define EXPLORER_RELEASES_API "https://api.github.com/repos/quzopl/explorer-thunar/releases/latest"
+
+typedef struct
+{
+  ThunarWindow *window;
+  gboolean      interactive;
+} ThunarExplorerUpdateCheck;
+
+static void
+thunar_window_explorer_update_check_done (GObject      *source,
+                                          GAsyncResult *result,
+                                          gpointer      user_data)
+{
+  ThunarExplorerUpdateCheck *check = user_data;
+  GSubprocess               *proc = G_SUBPROCESS (source);
+  GtkWidget                 *dialog;
+  gchar                     *out = NULL;
+  gchar                     *tag = NULL;
+  const gchar               *p;
+  const gchar               *end;
+
+  if (g_subprocess_communicate_utf8_finish (proc, result, &out, NULL, NULL)
+      && g_subprocess_get_successful (proc)
+      && out != NULL
+      && (p = strstr (out, "\"tag_name\"")) != NULL
+      && (p = strchr (p + 10, '"')) != NULL
+      && (end = strchr (p + 1, '"')) != NULL)
+    tag = g_strndup (p + 1, end - p - 1);
+
+  if (tag != NULL && g_strcmp0 (tag, EXPLORER_VERSION) != 0)
+    {
+      dialog = gtk_message_dialog_new (GTK_WINDOW (check->window),
+                                       GTK_DIALOG_DESTROY_WITH_PARENT,
+                                       GTK_MESSAGE_INFO, GTK_BUTTONS_NONE,
+                                       _("A new version of Explorer is available: %s (installed: %s)"),
+                                       tag, EXPLORER_VERSION);
+      gtk_dialog_add_buttons (GTK_DIALOG (dialog),
+                              _("_Close"), GTK_RESPONSE_CLOSE,
+                              _("Open _download page"), GTK_RESPONSE_ACCEPT, NULL);
+      if (gtk_dialog_run (GTK_DIALOG (dialog)) == GTK_RESPONSE_ACCEPT)
+        gtk_show_uri_on_window (GTK_WINDOW (check->window), EXPLORER_RELEASES_URL,
+                                gtk_get_current_event_time (), NULL);
+      gtk_widget_destroy (dialog);
+    }
+  else if (check->interactive && tag != NULL)
+    {
+      dialog = gtk_message_dialog_new (GTK_WINDOW (check->window),
+                                       GTK_DIALOG_DESTROY_WITH_PARENT,
+                                       GTK_MESSAGE_INFO, GTK_BUTTONS_CLOSE,
+                                       _("Explorer %s is up to date."), EXPLORER_VERSION);
+      gtk_dialog_run (GTK_DIALOG (dialog));
+      gtk_widget_destroy (dialog);
+    }
+  else if (check->interactive)
+    {
+      dialog = gtk_message_dialog_new (GTK_WINDOW (check->window),
+                                       GTK_DIALOG_DESTROY_WITH_PARENT,
+                                       GTK_MESSAGE_WARNING, GTK_BUTTONS_CLOSE, "%s",
+                                       _("Could not check for updates. Check your network connection."));
+      gtk_dialog_run (GTK_DIALOG (dialog));
+      gtk_widget_destroy (dialog);
+    }
+
+  g_free (tag);
+  g_free (out);
+  g_object_unref (check->window);
+  g_slice_free (ThunarExplorerUpdateCheck, check);
+}
+
+static void
+thunar_window_explorer_check_updates (ThunarWindow *window,
+                                      gboolean      interactive)
+{
+  ThunarExplorerUpdateCheck *check;
+  GSubprocess               *proc;
+
+  proc = g_subprocess_new (G_SUBPROCESS_FLAGS_STDOUT_PIPE | G_SUBPROCESS_FLAGS_STDERR_SILENCE,
+                           NULL, "curl", "-fsSL", "-m", "10",
+                           "-H", "Accept: application/vnd.github+json",
+                           EXPLORER_RELEASES_API, NULL);
+  if (proc == NULL)
+    {
+      if (interactive)
+        {
+          GtkWidget *dialog = gtk_message_dialog_new (GTK_WINDOW (window),
+                                                      GTK_DIALOG_DESTROY_WITH_PARENT,
+                                                      GTK_MESSAGE_WARNING, GTK_BUTTONS_CLOSE, "%s",
+                                                      _("Could not check for updates: 'curl' is not installed."));
+          gtk_dialog_run (GTK_DIALOG (dialog));
+          gtk_widget_destroy (dialog);
+        }
+      return;
+    }
+
+  check = g_slice_new0 (ThunarExplorerUpdateCheck);
+  check->window = g_object_ref (window);
+  check->interactive = interactive;
+  g_subprocess_communicate_utf8_async (proc, NULL, NULL,
+                                       thunar_window_explorer_update_check_done, check);
+  g_object_unref (proc);
+}
+
+static void
+thunar_window_explorer_check_updates_manual (ThunarWindow *window)
+{
+  thunar_window_explorer_check_updates (window, TRUE);
+}
