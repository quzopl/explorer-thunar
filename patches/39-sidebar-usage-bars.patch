+/* Explorer: procent zajetosci woluminu (jak karty urzadzen w NOVA).
+ * Cache 60 s; tylko natywne punkty montowania (sieciowe by blokowaly UI). */
+static gint
+thunar_shortcuts_view_explorer_usage (GFile *root)
+{
+  typedef struct { gint pct; gint64 when; } UsageEntry;
+  static GHashTable *cache = NULL;
+  UsageEntry *entry;
+  GFileInfo  *info;
+  gchar      *uri;
+  gint64      now = g_get_monotonic_time ();
+  gint        pct = -1;
+
+  if (cache == NULL)
+    cache = g_hash_table_new_full (g_str_hash, g_str_equal, g_free, g_free);
+
+  uri = g_file_get_uri (root);
+  entry = g_hash_table_lookup (cache, uri);
+  if (entry != NULL && now - entry->when < (gint64) 60 * G_USEC_PER_SEC)
+    {
+      pct = entry->pct;
+      g_free (uri);
+      return pct;
+    }
+
+  if (g_file_is_native (root))
+    {
+      info = g_file_query_filesystem_info (root,
+                                           G_FILE_ATTRIBUTE_FILESYSTEM_SIZE ","
+                                           G_FILE_ATTRIBUTE_FILESYSTEM_USED,
+                                           NULL, NULL);
+      if (info != NULL)
+        {
+          guint64 size = g_file_info_get_attribute_uint64 (info, G_FILE_ATTRIBUTE_FILESYSTEM_SIZE);
+          guint64 used = g_file_info_get_attribute_uint64 (info, G_FILE_ATTRIBUTE_FILESYSTEM_USED);
+          if (size > 0)
+            pct = (gint) ((used * 100 + size / 2) / size);
+          g_object_unref (info);
+        }
+    }
+
+  entry = g_new0 (UsageEntry, 1);
+  entry->pct = pct;
+  entry->when = now;
+  g_hash_table_replace (cache, uri, entry);
+  return pct;
+}
+
+static void
+thunar_shortcuts_view_explorer_usage_cell (GtkTreeViewColumn *column,
+                                           GtkCellRenderer   *renderer,
+                                           GtkTreeModel      *model,
+                                           GtkTreeIter       *iter,
+                                           gpointer           user_data)
+{
+  ThunarDevice *device = NULL;
+  GFile        *root = NULL;
+  guint         group = 0;
+  gint          pct = -1;
+
+  gtk_tree_model_get (model, iter,
+                      THUNAR_SHORTCUTS_MODEL_COLUMN_DEVICE, &device,
+                      THUNAR_SHORTCUTS_MODEL_COLUMN_GROUP, &group,
+                      -1);
+
+  if (device != NULL && thunar_device_is_mounted (device))
+    root = thunar_device_get_root (device);
+  else if (device == NULL && (group & THUNAR_SHORTCUT_GROUP_DEVICES_FILESYSTEM) != 0)
+    root = g_file_new_for_path ("/");
+
+  if (root != NULL)
+    {
+      pct = thunar_shortcuts_view_explorer_usage (root);
+      g_object_unref (root);
+    }
+  if (device != NULL)
+    g_object_unref (device);
+
+  g_object_set (renderer,
+                "visible", pct >= 0,
+                "value", pct < 0 ? 0 : pct,
+                NULL);
+}
