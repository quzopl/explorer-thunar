 } ThunarExplorerUpdateCheck;
 
+/* porownanie wersji "vX.Y.Z" po czlonach; >0 gdy a nowsza niz b */
+static gint
+thunar_explorer_version_cmp (const gchar *a,
+                             const gchar *b)
+{
+  gchar **pa;
+  gchar **pb;
+  gint    i;
+  gint    r = 0;
+
+  if (a != NULL && *a == 'v')
+    a++;
+  if (b != NULL && *b == 'v')
+    b++;
+  pa = g_strsplit (a != NULL ? a : "", ".", -1);
+  pb = g_strsplit (b != NULL ? b : "", ".", -1);
+  for (i = 0; r == 0 && (pa[i] != NULL || pb[i] != NULL); i++)
+    {
+      gint64 na = pa[i] != NULL ? g_ascii_strtoll (pa[i], NULL, 10) : 0;
+      gint64 nb = pb[i] != NULL ? g_ascii_strtoll (pb[i], NULL, 10) : 0;
+      r = (na > nb) - (na < nb);
+    }
+  g_strfreev (pa);
+  g_strfreev (pb);
+  return r;
+}
+
