+
+/* Explorer: uklad "plywajacych paneli" NOVA — marginesy wokol paneli,
+ * wlaczane tylko dla palet nova-* i aktualizowane przy zmianie motywu */
+static void
+thunar_window_explorer_nova_layout (ThunarWindow *window)
+{
+  XfconfChannel *channel = xfconf_channel_get ("explorer");
+  gchar         *slug = xfconf_channel_get_string (channel, "/explorer-theme", "fluent-dark");
+  gboolean       nova = slug != NULL && g_str_has_prefix (slug, "nova-");
+  gint           m = nova ? 10 : 0;
+
+  gtk_widget_set_margin_start (window->paned, m);
+  gtk_widget_set_margin_end (window->paned, m);
+  gtk_widget_set_margin_bottom (window->paned, m);
+  gtk_widget_set_margin_top (window->paned, nova ? 4 : 0);
+  g_free (slug);
+}
+
+static void
+thunar_window_explorer_theme_prop_changed (XfconfChannel *channel,
+                                           const gchar   *property,
+                                           const GValue  *value,
+                                           gpointer       user_data)
+{
+  thunar_window_explorer_nova_layout (THUNAR_WINDOW (user_data));
+}
