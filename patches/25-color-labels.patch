+/* Explorer: etykiety kolorów jak w Finderze — zapisują wbudowane w Thunara
+ * podświetlenie pliku (metadane gvfs thunar-highlight-color-*), rysowane
+ * przez widoki, gdy misc-highlighting-enabled. */
+typedef struct
+{
+  const gchar *label;
+  const gchar *background;
+  const gchar *foreground;
+} ThunarExplorerColorLabel;
+
+static const ThunarExplorerColorLabel thunar_explorer_color_labels[] = {
+  { N_ ("Red"), "#c94f4f", "#ffffff" },
+  { N_ ("Orange"), "#cf7f2e", "#ffffff" },
+  { N_ ("Yellow"), "#c9a800", "#1a1a1a" },
+  { N_ ("Green"), "#3f9a50", "#ffffff" },
+  { N_ ("Blue"), "#3a76c4", "#ffffff" },
+  { N_ ("Purple"), "#8b5fbf", "#ffffff" },
+  { N_ ("Gray"), "#7a7d85", "#ffffff" },
+};
+
+
+
+static void
+thunar_menu_explorer_color_label_files_free (gpointer data)
+{
+  thunar_g_list_free_full ((GList *) data);
+}
+
+
+
+static void
+thunar_menu_explorer_color_label_activate (GtkWidget *item,
+                                           gpointer   user_data)
+{
+  GList             *files;
+  const gchar       *bg;
+  const gchar       *fg;
+  ThunarJob         *job;
+  ThunarPreferences *preferences;
+
+  files = g_object_get_data (G_OBJECT (item), "explorer-color-label-files");
+  if (files == NULL)
+    return;
+
+  bg = g_object_get_data (G_OBJECT (item), "explorer-color-label-bg");
+  fg = g_object_get_data (G_OBJECT (item), "explorer-color-label-fg");
+
+  if (bg != NULL)
+    {
+      /* jak dialog Właściwości: nadanie etykiety włącza rysowanie podświetleń */
+      preferences = thunar_preferences_get ();
+      g_object_set (G_OBJECT (preferences), "misc-highlighting-enabled", TRUE, NULL);
+      g_object_unref (preferences);
+
+      job = thunar_io_jobs_set_metadata_for_files (files, THUNAR_GTYPE_STRING,
+                                                   "thunar-highlight-color-background", bg,
+                                                   "thunar-highlight-color-foreground", fg,
+                                                   NULL);
+    }
+  else
+    {
+      job = thunar_io_jobs_clear_metadata_for_files (files,
+                                                     "thunar-highlight-color-background",
+                                                     "thunar-highlight-color-foreground",
+                                                     NULL);
+    }
+
+  /* zwolnij nasz ref po zakończeniu zadania */
+  g_signal_connect_swapped (job, "finished", G_CALLBACK (g_object_unref), job);
+  exo_job_launch (EXO_JOB (job));
+}
+
+
+
+static gboolean
+thunar_menu_explorer_append_color_labels (ThunarMenu *menu)
+{
+  GList     *selected_files = NULL;
+  GtkWidget *item;
+  GtkWidget *submenu;
+  GtkWidget *child;
+  GtkWidget *label;
+  gchar     *markup;
+  guint      i;
+
+  g_object_get (G_OBJECT (menu->action_mgr), "selected-files", &selected_files, NULL);
+  if (selected_files == NULL)
+    return FALSE;
+
+  item = gtk_menu_item_new_with_mnemonic (_("Color _Label"));
+  submenu = gtk_menu_new ();
+  gtk_menu_item_set_submenu (GTK_MENU_ITEM (item), submenu);
+
+  /* pozycje kolorów + oddzielone "None" czyszczące etykietę */
+  for (i = 0; i <= G_N_ELEMENTS (thunar_explorer_color_labels); i++)
+    {
+      gboolean     is_clear = (i == G_N_ELEMENTS (thunar_explorer_color_labels));
+      const gchar *bg = is_clear ? NULL : thunar_explorer_color_labels[i].background;
+
+      if (is_clear)
+        gtk_menu_shell_append (GTK_MENU_SHELL (submenu), gtk_separator_menu_item_new ());
+
+      child = gtk_menu_item_new ();
+      label = gtk_label_new (NULL);
+      if (is_clear)
+        markup = g_strdup_printf ("\xe2\x97\x8b  %s", _("None"));
+      else
+        markup = g_strdup_printf ("<span foreground=\"%s\">\xe2\x97\x8f</span>  %s",
+                                  bg, _(thunar_explorer_color_labels[i].label));
+      gtk_label_set_markup (GTK_LABEL (label), markup);
+      gtk_label_set_xalign (GTK_LABEL (label), 0.0f);
+      g_free (markup);
+      gtk_container_add (GTK_CONTAINER (child), label);
+
+      g_object_set_data_full (G_OBJECT (child), "explorer-color-label-files",
+                              thunar_g_list_copy_deep (selected_files),
+                              thunar_menu_explorer_color_label_files_free);
+      g_object_set_data (G_OBJECT (child), "explorer-color-label-bg", (gpointer) bg);
+      g_object_set_data (G_OBJECT (child), "explorer-color-label-fg",
+                         is_clear ? NULL : (gpointer) thunar_explorer_color_labels[i].foreground);
+      g_signal_connect (child, "activate",
+                        G_CALLBACK (thunar_menu_explorer_color_label_activate), NULL);
+      gtk_menu_shell_append (GTK_MENU_SHELL (submenu), child);
+    }
+
+  thunar_g_list_free_full (selected_files);
+  gtk_menu_shell_append (GTK_MENU_SHELL (menu), item);
+  return TRUE;
+}
+
