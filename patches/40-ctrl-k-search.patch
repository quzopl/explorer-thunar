+/* Explorer: Ctrl+K -> fokus na polu wyszukiwania (jak "Szukaj lub wpisz
+ * polecenie / Ctrl K" w mockupie NOVA) */
+static gboolean
+thunar_window_explorer_search_key (GtkWidget   *widget,
+                                   GdkEventKey *event,
+                                   gpointer     user_data)
+{
+  ThunarWindow *window = THUNAR_WINDOW (widget);
+
+  if ((event->state & gtk_accelerator_get_default_mod_mask ()) == GDK_CONTROL_MASK
+      && (event->keyval == GDK_KEY_k || event->keyval == GDK_KEY_K)
+      && window->explorer_search_entry != NULL
+      && gtk_widget_get_visible (window->explorer_search_entry))
+    {
+      gtk_widget_grab_focus (window->explorer_search_entry);
+      return TRUE;
+    }
+
+  return FALSE;
+}
